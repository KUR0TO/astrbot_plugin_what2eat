{
  "version": {
    "type": "int",
    "description": "Config version",
    "hint": "Internal config version used by plugin normalization.",
    "default": 1,
    "invisible": true
  },
  "categories": {
    "type": "template_list",
    "description": "Meal categories",
    "hint": "Each category has id/label/enabled and tree_json.",
    "templates": {
      "category": {
        "name": "Category",
        "items": {
          "id": {
            "type": "string",
            "description": "Category id"
          },
          "label": {
            "type": "string",
            "description": "Category label"
          },
          "enabled": {
            "type": "bool",
            "description": "Enabled"
          },
          "tree": {
            "type": "text",
            "description": "Category tree JSON",
            "hint": "Provide JSON object with id/label/weight/flavors/children/items.",
            "editor_mode": true,
            "editor_language": "json",
            "editor_theme": "vs-light"
          }
        }
      }
    },
    "default": [
      {
        "__template_key": "category",
        "id": "main",
        "label": "Main",
        "enabled": true,
        "tree": "{\n  \"id\": \"root_main\",\n  \"label\": \"Main\",\n  \"weight\": 1,\n  \"flavors\": [],\n  \"children\": [],\n  \"items\": [\n    {\n      \"id\": \"item_main\",\n      \"label\": \"rice/noodle/bread\",\n      \"weight\": 1,\n      \"flavors\": [],\n      \"children\": [],\n      \"items\": []\n    }\n  ]\n}"
      },
      {
        "__template_key": "category",
        "id": "side",
        "label": "Side",
        "enabled": true,
        "tree": "{\n  \"id\": \"root_side\",\n  \"label\": \"Side\",\n  \"weight\": 1,\n  \"flavors\": [],\n  \"children\": [],\n  \"items\": [\n    {\n      \"id\": \"item_side\",\n      \"label\": \"vegetables/meat\",\n      \"weight\": 1,\n      \"flavors\": [],\n      \"children\": [],\n      \"items\": []\n    }\n  ]\n}"
      },
      {
        "__template_key": "category",
        "id": "drink",
        "label": "Drink",
        "enabled": true,
        "tree": "{\n  \"id\": \"root_drink\",\n  \"label\": \"Drink\",\n  \"weight\": 1,\n  \"flavors\": [],\n  \"children\": [],\n  \"items\": [\n    {\n      \"id\": \"item_drink\",\n      \"label\": \"tea/juice/soda\",\n      \"weight\": 1,\n      \"flavors\": [],\n      \"children\": [],\n      \"items\": []\n    }\n  ]\n}"
      }
    ]
  },
  "flavors": {
    "type": "template_list",
    "description": "Flavor tags",
    "hint": "Define flavor ids used by tree nodes and filters.",
    "templates": {
      "flavor": {
        "name": "Flavor",
        "items": {
          "id": {
            "type": "string",
            "description": "Flavor id"
          },
          "label": {
            "type": "string",
            "description": "Flavor label"
          },
          "description": {
            "type": "string",
            "description": "Flavor description",
            "default": ""
          },
          "enabled_by_default": {
            "type": "bool",
            "description": "Enabled by default",
            "default": false
          }
        }
      }
    },
    "default": []
  },
  "toggles": {
    "type": "object",
    "description": "Current toggle states",
    "hint": "Enable/disable categories and active flavor filters.",
    "items": {
      "flavors": {
        "type": "list",
        "description": "Active flavor filter ids",
        "hint": "Flavor ids used for filtering when generating results.",
        "default": []
      }
    }
  }
}
